                    "process_state": "Terminated"
                }
            },
            "deployment_config": {
                "ready_timeout": 0.5,
                "shutdown_timeout": 0.5,
                "environmental_variables": [],
                "bin_dir": "/opt/scripts",
                "working_dir": "/tmp",
                "ready_recovery_action_type": "RestartAction",
                "ready_recovery_action": {
