                },
                "sandbox": {
                    "uid": 3,
                    "gid": 1000,
                    "supplementary_group_ids": [],
                    "security_policy": "",
                    "scheduling_policy": "SCHED_OTHER",
                    "scheduling_priority": 0
                }
            }
        }
